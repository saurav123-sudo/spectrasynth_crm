{
  "name": "chem-price-scraper",
  "version": "1.0.0",
  "description": "Scrapes chemical prices from TCI, Sigma-Aldrich, Ambeed, BLD Pharm by name or CAS number",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test:tci": "node -e \"require('./scrapers/tci')('50-78-2').then(r => console.log(JSON.stringify(r, null, 2)))\"",
    "test:sigma": "node -e \"require('./scrapers/sigma')('50-78-2').then(r => console.log(JSON.stringify(r, null, 2)))\"",
    "test:ambeed": "node -e \"require('./scrapers/ambeed')('50-78-2').then(r => console.log(JSON.stringify(r, null, 2)))\"",
    "test:bld": "node -e \"require('./scrapers/bldpharm')('50-78-2').then(r => console.log(JSON.stringify(r, null, 2)))\""
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "opentype.js": "^1.3.4",
    "puppeteer": "^24.0.0"
  }
}
